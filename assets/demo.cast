[4.29, "o", "\r\n"]
[4.41, "o", "\u001b[1;38;2;45;212;191m █████╗ ██╗    ███╗   ███╗███████╗███╗   ███╗ ██████╗ ██████╗ ██╗   ██╗\u001b[0m\r\n"]
[4.53, "o", "\u001b[1;38;2;56;189;248m██╔══██╗██║    ████╗ ████║██╔════╝████╗ ████║██╔═══██╗██╔══██╗╚██╗ ██╔╝\u001b[0m\r\n"]
[4.65, "o", "\u001b[1;38;2;59;130;246m███████║██║    ██╔████╔██║█████╗  ██╔████╔██║██║   ██║██████╔╝ ╚████╔╝ \u001b[0m\r\n"]
[4.77, "o", "\u001b[1;38;2;99;102;241m██╔══██║██║    ██║╚██╔╝██║██╔══╝  ██║╚██╔╝██║██║   ██║██╔══██╗  ╚██╔╝  \u001b[0m\r\n"]
[4.89, "o", "\u001b[1;38;2;139;92;246m██║  ██║██║    ██║ ╚═╝ ██║███████╗██║ ╚═╝ ██║╚██████╔╝██║  ██║   ██║   \u001b[0m\r\n"]
[5.01, "o", "\u001b[1;38;2;168;85;247m╚═╝  ╚═╝╚═╝    ╚═╝     ╚═╝╚══════╝╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝   \u001b[0m\r\n"]
[5.11, "o", "\u001b[2m   persistent, agent-agnostic session memory · one vault, any CLI\u001b[0m\r\n"]
[5.14, "o", "\r\n"]
[5.77, "o", "  Where should your memory vault live? \u001b[2m[~/.ai-memory/_Ai_Memory]\u001b[0m "]
[6.9, "o", "\r\n"]
[7.23, "o", "  Which agents should get <agent>-start launchers? \u001b[2m[claude codex gemini cursor opencode]\u001b[0m "]
[8.36, "o", "\r\n"]
[8.39, "o", "\r\n"]
[8.72, "o", "  scaffolding vault at: ~/.ai-memory/_Ai_Memory\r\n"]
[8.93, "o", "    \u001b[32mcreate\u001b[0m _Global_Profile.md\r\n"]
[9.14, "o", "    \u001b[32mcreate\u001b[0m _Standards.md\r\n"]
[9.35, "o", "    \u001b[32mcreate\u001b[0m _project_template.md\r\n"]
[9.56, "o", "    \u001b[32mcreate\u001b[0m _session_template.md\r\n"]
[9.59, "o", "\r\n"]
[10.02, "o", "  Append the setup lines to ~/.zshrc now? \u001b[2m[Y/n]\u001b[0m "]
[11.05, "o", "\r\n"]
[11.38, "o", "  \u001b[32madded\u001b[0m to ~/.zshrc\r\n"]
[11.41, "o", "\r\n"]
[11.44, "o", "  Reload your shell:  \u001b[1mexec zsh\u001b[0m\r\n"]
[11.47, "o", "\r\n"]
[11.8, "o", "  \u001b[1;38;2;56;189;248mDone.\u001b[0m From inside any git repo, run:  \u001b[1mclaude-start\u001b[0m\r\n"]
[11.83, "o", "  \u001b[2m(or codex-start / gemini-start / cursor-start / opencode-start)\u001b[0m\r\n"]
[11.86, "o", "\r\n"]
